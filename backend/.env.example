# Copy to .env for local dev. All optional. With RF_LLM_STUB unset/false and no
# Cortex URL, the app auto-detects a local LLM (Ollama by default) and only
# falls back to the deterministic stub if none is reachable. Set RF_LLM_STUB=true
# to force the stub (tests/CI), or a Cortex base URL to use the hosted LLM.

RF_ENVIRONMENT=dev
RF_LOG_LEVEL=INFO

# --- Cortex LLM (hosted; takes precedence when set) ---
# RF_LLM_STUB=true
# RF_LLM_BASE_URL=https://cortex.example.corp/v1
# RF_LLM_MODEL=cortex-default
# RF_LLM_TOKEN_URL=https://login.example.corp/oauth2/token
# RF_LLM_CLIENT_ID=
# RF_LLM_CLIENT_SECRET=
# RF_LLM_SCOPE=cortex.completions

# --- Local LLM (Ollama / LM Studio / vLLM — used when Cortex is absent) ---
# RF_LOCAL_LLM_BASE_URL=http://localhost:11434/v1   # Ollama default; LM Studio: http://localhost:1234/v1
# RF_LOCAL_LLM_MODEL=                                # empty ⇒ first model the server reports
# RF_LOCAL_LLM_TIMEOUT=600

# --- Pipeline ---
RF_MAX_RETRIES=2
RF_BATCH_CONCURRENCY=4
RF_SECRET_POLICY=block

# --- Outbound (corporate proxy / TLS) ---
# RF_HTTPS_PROXY=http://proxy.example.corp:8080
# RF_CA_BUNDLE_PATH=/etc/ssl/certs/corp-ca.pem

# --- Optional add-ons ---
# RF_REDIS_URL=redis://localhost:6379/0
# RF_DATABASE_URL=postgresql+psycopg://readmint:readmint@localhost:5432/readmint
# RF_GH_APP_ID=
# RF_GH_INSTALLATION_ID=
# RF_GH_PRIVATE_KEY=
# RF_CONFLUENCE_BASE_URL=
# RF_CONFLUENCE_TOKEN=
# RF_CONFLUENCE_SPACE=

# --- Auth (oauth2-proxy injects headers in prod) ---
RF_AUTH_ENABLED=false
RF_ADMIN_GROUPS=readmint-admins
